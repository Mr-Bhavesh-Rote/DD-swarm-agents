# .env.example — copy to .env and fill in; never commit .env

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEFAULT_MODEL=claude-sonnet-4-6
RESEARCH_MODEL=claude-sonnet-4-6       # default for the research swarm
VERIFIER_MODEL=claude-sonnet-4-6

# --- Observability (Langfuse v3 reads these automatically) ---
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com   # or self-hosted URL

# --- Search / tools ---
TAVILY_API_KEY=your_tavily_api_key_here
SCRAPER_USER_AGENT=deep-dd-bot/1.0
REQUEST_TIMEOUT_SECONDS=30             # HTTP scraping timeout
LLM_TIMEOUT_SECONDS=120               # Anthropic call timeout (large completions need headroom)
LLM_MAX_RETRIES=2                     # client-level retries on transient API errors

# --- Content depth (raise for richer/longer reports; lower to cut cost/latency) ---
SEARCH_MAX_RESULTS=8                   # results returned per web_search
SEARCH_DEPTH=basic                     # basic (fast) | advanced (slower, deeper crawl)
SEARCH_INCLUDE_RAW_CONTENT=true       # store full page text for the verifier (not dumped into the model context)
SCRAPE_MAX_CHARS=50000                 # per-page extracted text cap
RESEARCH_MAX_TOKENS=8000               # max output tokens per research agent (raw detail)
AGGREGATOR_MAX_TOKENS=4000
SYNTHESIZER_MAX_TOKENS=16000           # max output tokens for the FINAL report draft
VERIFIER_MAX_TOKENS=4000               # per verification batch
VERIFIER_SOURCE_CHARS=6000             # source text shown to the verifier per claim

# --- Database & jobs ---
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/deepdd
REDIS_URL=redis://localhost:6379/0

# --- Workflow tuning ---
MAX_REVISIONS=1                        # verifier→writer revise-loop cap (each revision re-runs the writer + verifier)
REVISION_MIN_FAITHFULNESS=0.7          # skip the revise loop if faithfulness ≥ this (big speedup for good reports)
MAX_SUBAGENTS=1
RECURSION_LIMIT=50
RUN_BUDGET_USD=5                      # soft per-run cost ceiling (warn/abort)

# --- Auth & security ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY_MINUTES=120
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Storage (exports) ---
EXPORT_STORAGE_URI=file:///Users/rakeshsharma/Documents/WORK/Ai1stLab/TDI/code/osint-deep-research/deep-dd/.local-run/exports

# --- Frontend (Vite, build-time, NON-secret only) ---
VITE_API_BASE_URL=http://localhost:8000
