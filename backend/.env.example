# .env.example — copy to .env and fill in; never commit .env

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEFAULT_MODEL=claude-opus-4-8          # system fallback for any unset role/agent
RESEARCH_MODEL=claude-sonnet-4-6       # default for the research swarm
VERIFIER_MODEL=claude-opus-4-8

# --- Observability (Langfuse v3 reads these automatically) ---
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_HOST=https://cloud.langfuse.com   # or self-hosted URL

# --- Search / tools ---
TAVILY_API_KEY=your_tavily_api_key_here
SCRAPER_USER_AGENT=deep-dd-bot/1.0
REQUEST_TIMEOUT_SECONDS=30             # HTTP scraping timeout
LLM_TIMEOUT_SECONDS=120               # Anthropic call timeout (large completions need headroom)
LLM_MAX_RETRIES=2                     # client-level retries on transient API errors

# --- Database & jobs ---
DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/deepdd
REDIS_URL=redis://localhost:6379/0

# --- Workflow tuning ---
MAX_REVISIONS=2                        # verifier→writer revise-loop cap
MAX_SUBAGENTS=8                        # swarm size cap
RECURSION_LIMIT=5
RUN_BUDGET_USD=10                      # soft per-run cost ceiling (warn/abort)

# --- Auth & security ---
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY_MINUTES=120
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Storage (exports) ---
EXPORT_STORAGE_URI=file:///var/deepdd/exports   # or s3://bucket/prefix

# --- Frontend (Vite, build-time, NON-secret only) ---
VITE_API_BASE_URL=http://localhost:8000
